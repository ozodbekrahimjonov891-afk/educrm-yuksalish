<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>EduCRM — Yuksalish</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0a0e1a;--surface:#111827;--surface2:#1a2235;--surface3:#1e2d45;
  --accent:#3b82f6;--accent2:#06b6d4;--green:#10b981;--orange:#f59e0b;
  --red:#ef4444;--purple:#8b5cf6;--text:#f1f5f9;--text2:#94a3b8;--text3:#475569;
  --border:#1e3a5f;--border2:#243b55;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%;font-family:'Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--text);overflow:hidden}

/* ── LAYOUT ── */
.app{display:flex;flex-direction:column;height:100vh;height:100dvh}
.topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 16px;height:56px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.topbar-title{font-size:16px;font-weight:800}
.topbar-right{display:flex;gap:8px}
.page-wrap{flex:1;overflow-y:auto;padding:16px;padding-bottom:80px}
.bottom-nav{position:fixed;bottom:0;left:0;right:0;background:var(--surface);border-top:1px solid var(--border);display:flex;height:64px;z-index:100}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;font-size:10px;font-weight:600;color:var(--text3);cursor:pointer;transition:color .2s;border:none;background:none;font-family:'Plus Jakarta Sans',sans-serif;position:relative}
.nav-btn.active{color:var(--accent)}
.nav-btn .icon{font-size:22px}
.nav-btn .dot{position:absolute;top:8px;right:calc(50% - 16px);width:7px;height:7px;background:var(--red);border-radius:50%;display:none}
.nav-btn .dot.show{display:block}

/* ── PAGES ── */
.page{display:none}.page.active{display:block}

/* ── CARDS ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:12px}
.card-header{padding:14px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.card-title{font-size:14px;font-weight:700}

/* ── STAT CARDS ── */
.stats-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
.stat{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px}
.stat-label{font-size:11px;color:var(--text2);font-weight:600;margin-bottom:4px}
.stat-val{font-size:26px;font-weight:800}
.stat-val.blue{color:var(--accent)}
.stat-val.green{color:var(--green)}
.stat-val.orange{color:var(--orange)}
.stat-val.purple{color:var(--purple)}

/* ── LIST ITEMS ── */
.list-item{display:flex;align-items:center;gap:12px;padding:13px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .15s}
.list-item:last-child{border-bottom:none}
.list-item:active{background:var(--surface2)}
.av{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--accent),var(--purple));display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;flex-shrink:0}
.av.green{background:linear-gradient(135deg,var(--green),var(--accent2))}
.av.orange{background:linear-gradient(135deg,var(--orange),var(--red))}
.item-info{flex:1;min-width:0}
.item-name{font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.item-sub{font-size:12px;color:var(--text2);margin-top:1px}
.item-right{text-align:right;flex-shrink:0}

/* ── STATUS ── */
.badge{padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;display:inline-block}
.badge.paid{background:rgba(16,185,129,.15);color:var(--green);border:1px solid rgba(16,185,129,.3)}
.badge.debt{background:rgba(239,68,68,.15);color:var(--red);border:1px solid rgba(239,68,68,.3)}
.badge.pending{background:rgba(245,158,11,.15);color:var(--orange);border:1px solid rgba(245,158,11,.3)}
.badge.active{background:rgba(16,185,129,.15);color:var(--green);border:1px solid rgba(16,185,129,.3)}

/* ── BUTTONS ── */
.btn{padding:12px 20px;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;border:none;font-family:'Plus Jakarta Sans',sans-serif;transition:all .2s}
.btn-primary{background:var(--accent);color:#fff;width:100%}
.btn-primary:active{background:#2563eb}
.btn-ghost{background:var(--surface2);color:var(--text2);border:1px solid var(--border2);width:100%}
.btn-sm{padding:7px 14px;font-size:12px;border-radius:8px;cursor:pointer;border:1px solid var(--border2);background:var(--surface2);color:var(--text2);font-family:'Plus Jakarta Sans',sans-serif;font-weight:600}
.btn-sm.green{border-color:rgba(16,185,129,.4);color:var(--green);background:rgba(16,185,129,.1)}
.btn-sm.red{border-color:rgba(239,68,68,.4);color:var(--red);background:rgba(239,68,68,.1)}
.fab{position:fixed;bottom:76px;right:16px;width:52px;height:52px;border-radius:50%;background:var(--accent);color:#fff;font-size:24px;border:none;cursor:pointer;box-shadow:0 4px 16px rgba(59,130,246,.4);display:flex;align-items:center;justify-content:center;z-index:99}

/* ── MODAL (bottom sheet) ── */
.sheet-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:200;align-items:flex-end;backdrop-filter:blur(3px)}
.sheet-overlay.open{display:flex}
.sheet{background:var(--surface);border-radius:20px 20px 0 0;padding:20px 16px 32px;width:100%;max-height:90vh;overflow-y:auto;animation:sheetUp .3s ease}
@keyframes sheetUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.sheet-handle{width:36px;height:4px;background:var(--border2);border-radius:2px;margin:0 auto 16px}
.sheet-title{font-size:17px;font-weight:800;margin-bottom:18px}
.form-group{margin-bottom:14px}
.form-label{font-size:12px;color:var(--text2);font-weight:600;margin-bottom:5px;display:block}
.form-input{width:100%;padding:12px 14px;border-radius:10px;border:1px solid var(--border2);background:var(--surface2);color:var(--text);font-size:14px;font-family:'Plus Jakarta Sans',sans-serif;outline:none;-webkit-appearance:none}
.form-input:focus{border-color:var(--accent)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.sheet-btns{display:flex;gap:10px;margin-top:18px}
.sheet-btns .btn{flex:1}

/* ── SEARCH ── */
.search-wrap{position:relative;margin-bottom:12px}
.search-wrap input{width:100%;padding:11px 14px 11px 38px;border-radius:10px;border:1px solid var(--border);background:var(--surface2);color:var(--text);font-size:14px;font-family:'Plus Jakarta Sans',sans-serif;outline:none}
.search-wrap::before{content:"🔍";position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:14px}

/* ── ATTENDANCE SPECIAL ── */
.att-item{display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border)}
.att-item:last-child{border-bottom:none}
.att-btns{display:flex;gap:6px;margin-left:auto}

/* ── EMPTY ── */
.empty{text-align:center;padding:40px 20px;color:var(--text3)}
.empty-icon{font-size:40px;margin-bottom:8px}
.empty-text{font-size:14px}

/* ── TOAST ── */
.toast{position:fixed;top:70px;left:50%;transform:translateX(-50%);background:var(--surface);border:1px solid var(--green);padding:12px 20px;border-radius:10px;font-size:13px;font-weight:600;z-index:999;white-space:nowrap;box-shadow:0 4px 20px rgba(0,0,0,.4);display:none}
.toast.show{display:block;animation:fadeIn .3s}
@keyframes fadeIn{from{opacity:0;transform:translateX(-50%) translateY(-6px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}

/* ── LOADING ── */
.loading{display:flex;align-items:center;justify-content:center;padding:30px;gap:10px;color:var(--text2)}
.spinner{width:18px;height:18px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── PROGRESS ── */
.progress{height:8px;background:var(--surface3);border-radius:4px;overflow:hidden}
.progress-bar{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--accent),var(--green));transition:width .5s}

/* ── SERVER STATUS ── */
.server-dot{width:8px;height:8px;border-radius:50%;background:var(--green);display:inline-block;margin-right:5px}
.server-dot.offline{background:var(--red)}
</style>
</head>
<body>
<div class="app">

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-title" id="topbar-title">📊 Dashboard</div>
    <div class="topbar-right">
      <span id="srv-dot" class="server-dot"></span>
    </div>
  </div>

  <!-- PAGES -->
  <div class="page-wrap">

    <!-- DASHBOARD -->
    <div class="page active" id="page-dashboard">
      <div class="stats-row">
        <div class="stat"><div class="stat-label">O'quvchilar</div><div class="stat-val blue" id="d-stu">—</div></div>
        <div class="stat"><div class="stat-label">O'qituvchilar</div><div class="stat-val purple" id="d-tea">—</div></div>
        <div class="stat"><div class="stat-label">Daromad (so'm)</div><div class="stat-val green" id="d-inc">—</div></div>
        <div class="stat"><div class="stat-label">Qarzdorlar</div><div class="stat-val orange" id="d-dbt">—</div></div>
      </div>
      <div class="card">
        <div class="card-header"><div class="card-title">📋 Oxirgi o'quvchilar</div></div>
        <div id="d-recent"></div>
      </div>
      <div class="card">
        <div class="card-header"><div class="card-title">💰 To'lov holati</div></div>
        <div style="padding:16px" id="d-pay-stat"></div>
      </div>
    </div>

    <!-- STUDENTS -->
    <div class="page" id="page-students">
      <div class="search-wrap"><input type="text" placeholder="Ism bo'yicha qidirish..." oninput="filterList('stu-list',this.value)"></div>
      <div class="card"><div id="stu-list"></div></div>
    </div>

    <!-- TEACHERS -->
    <div class="page" id="page-teachers">
      <div class="card"><div id="tea-list"></div></div>
    </div>

    <!-- GROUPS -->
    <div class="page" id="page-groups">
      <div class="card"><div id="grp-list"></div></div>
    </div>

    <!-- PAYMENTS -->
    <div class="page" id="page-payments">
      <div class="stats-row" style="grid-template-columns:1fr 1fr 1fr">
        <div class="stat"><div class="stat-label">To'langan</div><div class="stat-val green" id="p-paid" style="font-size:18px">0</div></div>
        <div class="stat"><div class="stat-label">Qarz</div><div class="stat-val orange" id="p-debt" style="font-size:18px">0</div></div>
        <div class="stat"><div class="stat-label">Jami</div><div class="stat-val blue" id="p-total" style="font-size:18px">0</div></div>
      </div>
      <div class="card"><div id="pay-list"></div></div>
    </div>

    <!-- ATTENDANCE -->
    <div class="page" id="page-attendance">
      <div class="card" style="margin-bottom:12px">
        <div style="padding:12px 16px;display:flex;align-items:center;justify-content:space-between">
          <div style="font-size:13px;font-weight:700">📅 Bugun: <span id="att-date" style="color:var(--accent2)"></span></div>
          <div style="font-size:12px;color:var(--text2)" id="att-summary"></div>
        </div>
      </div>
      <div class="card"><div id="att-list"></div></div>
    </div>

    <!-- REPORTS -->
    <div class="page" id="page-reports">
      <div id="rep-content"></div>
    </div>

  </div><!-- /page-wrap -->

  <!-- BOTTOM NAV -->
  <div class="bottom-nav">
    <button class="nav-btn active" onclick="showPage('dashboard',this)"><span class="icon">📊</span>Bosh</button>
    <button class="nav-btn" onclick="showPage('students',this)"><span class="icon">🎓</span>O'quvchilar<span class="dot" id="dot-stu"></span></button>
    <button class="nav-btn" onclick="showPage('payments',this)"><span class="icon">💰</span>To'lovlar<span class="dot" id="dot-pay"></span></button>
    <button class="nav-btn" onclick="showPage('attendance',this)"><span class="icon">✅</span>Davomat</button>
    <button class="nav-btn" onclick="showPage('more',this)"><span class="icon">☰</span>Ko'proq</button>
  </div>

</div><!-- /app -->

<!-- FAB -->
<button class="fab" id="fab" onclick="openAdd()">+</button>

<!-- MORE MENU (sheet) -->
<div class="sheet-overlay" id="sheet-more">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title">☰ Menyu</div>
    <div class="list-item" onclick="closeSheet('sheet-more');showPage('teachers',null)"><span style="font-size:20px;margin-right:4px">👨‍🏫</span> O'qituvchilar</div>
    <div class="list-item" onclick="closeSheet('sheet-more');showPage('groups',null)"><span style="font-size:20px;margin-right:4px">👥</span> Guruhlar</div>
    <div class="list-item" onclick="closeSheet('sheet-more');showPage('reports',null)"><span style="font-size:20px;margin-right:4px">📈</span> Hisobotlar</div>
  </div>
</div>

<!-- SHEET: O'quvchi qo'shish -->
<div class="sheet-overlay" id="sheet-student">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title">👨‍🎓 Yangi o'quvchi</div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Ism</label><input class="form-input" id="s-name" placeholder="Sardor"></div>
      <div class="form-group"><label class="form-label">Familiya</label><input class="form-input" id="s-surname" placeholder="Yusupov"></div>
    </div>
    <div class="form-group"><label class="form-label">Telefon</label><input class="form-input" id="s-phone" type="tel" placeholder="+998 90 000 00 00"></div>
    <div class="form-group"><label class="form-label">Guruh</label>
      <select class="form-input" id="s-group"><option value="">-- Tanlang --</option></select>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">To'lov holati</label>
        <select class="form-input" id="s-status">
          <option value="paid">✅ To'langan</option>
          <option value="debt">❌ Qarz</option>
          <option value="pending">⏳ Kutilmoqda</option>
        </select>
      </div>
      <div class="form-group"><label class="form-label">Summa (so'm)</label>
        <input class="form-input" id="s-amount" type="number" inputmode="numeric" placeholder="500000">
      </div>
    </div>
    <div class="sheet-btns">
      <button class="btn btn-ghost" onclick="closeSheet('sheet-student')">Bekor</button>
      <button class="btn btn-primary" onclick="submitStudent()">✅ Saqlash</button>
    </div>
  </div>
</div>

<!-- SHEET: O'qituvchi -->
<div class="sheet-overlay" id="sheet-teacher">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title">👨‍🏫 Yangi o'qituvchi</div>
    <div class="form-group"><label class="form-label">Ism Familiya</label><input class="form-input" id="t-name" placeholder="Jamshid Abdullayev"></div>
    <div class="form-group"><label class="form-label">Fan</label><input class="form-input" id="t-subject" placeholder="Matematika"></div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Telefon</label><input class="form-input" id="t-phone" type="tel"></div>
      <div class="form-group"><label class="form-label">Maosh (so'm)</label><input class="form-input" id="t-salary" type="number" inputmode="numeric"></div>
    </div>
    <div class="sheet-btns">
      <button class="btn btn-ghost" onclick="closeSheet('sheet-teacher')">Bekor</button>
      <button class="btn btn-primary" onclick="submitTeacher()">✅ Saqlash</button>
    </div>
  </div>
</div>

<!-- SHEET: Guruh -->
<div class="sheet-overlay" id="sheet-group">
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-title">👥 Yangi guruh</div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Guruh nomi</label><input class="form-input" id="g-name" placeholder="Kimyo A1"></div>
      <div class="form-group"><label class="form-label">Fan</label><input class="form-input" id="g-subject" placeholder="Kimyo"></div>
    </div>
    <div class="form-group"><label class="form-label">O'qituvchi</label>
      <select class="form-input" id="g-teacher"><option value="">-- Tanlang --</option></select>
    </div>
    <div class="form-group"><label class="form-label">Kunlar</label>
      <select class="form-input" id="g-days">
        <option>Toq kunlar (D, Ch, J)</option>
        <option>Juft kunlar (S, P, Sh)</option>
        <option>Har kuni</option>
      </select>
    </div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Boshlanish</label><input class="form-input" id="g-start" type="time" value="09:00"></div>
      <div class="form-group"><label class="form-label">Tugash</label><input class="form-input" id="g-end" type="time" value="10:30"></div>
    </div>
    <div class="sheet-btns">
      <button class="btn btn-ghost" onclick="closeSheet('sheet-group')">Bekor</button>
      <button class="btn btn-primary" onclick="submitGroup()">✅ Saqlash</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
const API = '';  // same origin — Railway da avtomatik ishlaydi
let currentPage = 'dashboard';

// ── API ──────────────────────────────────────────────
async function api(method, url, body=null){
  try{
    const r = await fetch(API+url,{method,headers:{'Content-Type':'application/json'},body:body?JSON.stringify(body):null});
    if(!r.ok){const e=await r.json().catch(()=>({}));throw new Error(e.error||'Xato')}
    return r.json();
  }catch(e){toast('❌ '+e.message,'red');throw e}
}

// ── NAV ──────────────────────────────────────────────
const pageTitles = {
  dashboard:'📊 Dashboard',students:'👨‍🎓 O\'quvchilar',teachers:'👨‍🏫 O\'qituvchilar',
  groups:'👥 Guruhlar',payments:'💰 To\'lovlar',attendance:'✅ Davomat',reports:'📈 Hisobotlar',more:'☰ Ko\'proq'
};

function showPage(name, el){
  if(name==='more'){openSheet('sheet-more');return}
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  if(el)el.classList.add('active');
  document.getElementById('topbar-title').textContent = pageTitles[name]||name;
  currentPage=name;
  loadPage(name);
}

async function loadPage(n){
  if(n==='dashboard')  return loadDashboard();
  if(n==='students')   return loadStudents();
  if(n==='teachers')   return loadTeachers();
  if(n==='groups')     return loadGroups();
  if(n==='payments')   return loadPayments();
  if(n==='attendance') return loadAttendance();
  if(n==='reports')    return loadReports();
}

// ── DASHBOARD ────────────────────────────────────────
async function loadDashboard(){
  const [stats,students,payments] = await Promise.all([
    api('GET','/api/stats'), api('GET','/api/students'), api('GET','/api/payments')
  ]);
  document.getElementById('d-stu').textContent = stats.students;
  document.getElementById('d-tea').textContent = stats.teachers;
  document.getElementById('d-inc').textContent = fmt(stats.income);
  document.getElementById('d-dbt').textContent = stats.debts;
  document.getElementById('dot-stu').classList.toggle('show', stats.students>0);
  document.getElementById('dot-pay').classList.toggle('show', stats.debts>0);

  const recent = students.slice(0,5);
  document.getElementById('d-recent').innerHTML = recent.length
    ? recent.map(s=>`<div class="list-item">
        <div class="av">${s.name[0]}</div>
        <div class="item-info"><div class="item-name">${s.name}</div><div class="item-sub">${s.group_name||'Guruhsiz'}</div></div>
        <div><span class="badge ${s.pay_status}">${payLbl(s.pay_status)}</span></div>
      </div>`).join('')
    : '<div class="empty"><div class="empty-icon">🎓</div><div class="empty-text">O\'quvchi yo\'q</div></div>';

  const paid=payments.filter(p=>p.status==='paid').reduce((a,b)=>a+(b.amount||0),0);
  const debt=payments.filter(p=>p.status==='debt').reduce((a,b)=>a+(b.amount||0),0);
  const total=paid+debt;
  const pct=total?Math.round(paid/total*100):0;
  document.getElementById('d-pay-stat').innerHTML = `
    <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:8px">
      <span>To'langan: <strong style="color:var(--green)">${fmt(paid)}</strong></span>
      <span>Qarz: <strong style="color:var(--red)">${fmt(debt)}</strong></span>
    </div>
    <div class="progress"><div class="progress-bar" style="width:${pct}%"></div></div>
    <div style="text-align:center;font-size:13px;color:var(--text2);margin-top:6px">${pct}% to'langan</div>`;
}

// ── STUDENTS ─────────────────────────────────────────
async function loadStudents(){
  const list = await api('GET','/api/students');
  renderStudents(list);
}
function renderStudents(list){
  document.getElementById('stu-list').innerHTML = list.length
    ? list.map(s=>`<div class="list-item" data-name="${s.name.toLowerCase()}">
        <div class="av">${s.name[0]}</div>
        <div class="item-info">
          <div class="item-name">${s.name}</div>
          <div class="item-sub">${s.group_name||'Guruhsiz'} · ${s.phone||'—'}</div>
        </div>
        <div class="item-right">
          <span class="badge ${s.pay_status}">${payLbl(s.pay_status)}</span>
          <div style="margin-top:5px"><button class="btn-sm red" onclick="delItem('students',${s.id})">🗑</button></div>
        </div>
      </div>`).join('')
    : '<div class="empty"><div class="empty-icon">🎓</div><div class="empty-text">O\'quvchi yo\'q<br>+ tugmasini bosing</div></div>';
}
let _allStudents=[];
async function loadStudentsWithCache(){
  _allStudents = await api('GET','/api/students');
  renderStudents(_allStudents);
}

// ── TEACHERS ─────────────────────────────────────────
async function loadTeachers(){
  const [teachers,groups] = await Promise.all([api('GET','/api/teachers'),api('GET','/api/groups')]);
  document.getElementById('tea-list').innerHTML = teachers.length
    ? teachers.map(t=>{
        const cnt=groups.filter(g=>g.teacher_id==t.id).length;
        return `<div class="list-item">
          <div class="av green">${t.name[0]}</div>
          <div class="item-info">
            <div class="item-name">${t.name}</div>
            <div class="item-sub">${t.subject||'—'} · ${cnt} ta guruh</div>
          </div>
          <div class="item-right">
            <div style="font-size:12px;color:var(--green);font-weight:700">${fmt(t.salary)}</div>
            <div style="font-size:10px;color:var(--text3)">so'm</div>
            <button class="btn-sm red" style="margin-top:5px" onclick="delItem('teachers',${t.id})">🗑</button>
          </div>
        </div>`;
      }).join('')
    : '<div class="empty"><div class="empty-icon">👨‍🏫</div><div class="empty-text">O\'qituvchi yo\'q</div></div>';
}

// ── GROUPS ───────────────────────────────────────────
async function loadGroups(){
  const groups = await api('GET','/api/groups');
  document.getElementById('grp-list').innerHTML = groups.length
    ? groups.map(g=>`<div class="list-item">
        <div class="av orange">${g.name[0]}</div>
        <div class="item-info">
          <div class="item-name">${g.name}</div>
          <div class="item-sub">${g.teacher_name||'—'} · ${g.student_count||0} o'quvchi</div>
        </div>
        <div class="item-right">
          <div style="font-size:11px;color:var(--text2)">${g.start_time||'?'}–${g.end_time||'?'}</div>
          <div style="font-size:10px;color:var(--text3);margin-top:2px">${(g.days||'').replace('kunlar','').trim()}</div>
          <button class="btn-sm red" style="margin-top:5px" onclick="delItem('groups',${g.id})">🗑</button>
        </div>
      </div>`).join('')
    : '<div class="empty"><div class="empty-icon">👥</div><div class="empty-text">Guruh yo\'q</div></div>';
}

// ── PAYMENTS ─────────────────────────────────────────
async function loadPayments(){
  const pays = await api('GET','/api/payments');
  const paid=pays.filter(p=>p.status==='paid').reduce((a,b)=>a+(b.amount||0),0);
  const debt=pays.filter(p=>p.status==='debt').reduce((a,b)=>a+(b.amount||0),0);
  document.getElementById('p-paid').textContent=fmt(paid);
  document.getElementById('p-debt').textContent=fmt(debt);
  document.getElementById('p-total').textContent=fmt(paid+debt);
  document.getElementById('pay-list').innerHTML = pays.length
    ? pays.map(p=>`<div class="list-item">
        <div class="av" style="background:linear-gradient(135deg,var(--green),var(--accent2))">${(p.student_name||'?')[0]}</div>
        <div class="item-info">
          <div class="item-name">${p.student_name||'—'}</div>
          <div class="item-sub">${p.group_name||'—'} · ${p.created_at||''}</div>
        </div>
        <div class="item-right">
          <div style="font-size:13px;font-weight:700;color:var(--green)">${fmt(p.amount)}</div>
          <span class="badge ${p.status}" style="margin-top:3px;display:block">${payLbl(p.status)}</span>
          ${p.status==='debt'?`<button class="btn-sm green" style="margin-top:5px" onclick="markPaid(${p.id})">✅ To'landi</button>`:''}
        </div>
      </div>`).join('')
    : '<div class="empty"><div class="empty-icon">💰</div><div class="empty-text">To\'lov yo\'q</div></div>';
}
async function markPaid(id){
  await api('PUT',`/api/payments/${id}/pay`);
  toast('✅ To\'lov tasdiqlandi!');
  loadPayments();
}

// ── ATTENDANCE ───────────────────────────────────────
async function loadAttendance(){
  const att = await api('GET','/api/attendance');
  const d=new Date();
  document.getElementById('att-date').textContent=d.toLocaleDateString('uz-UZ');
  const came=att.filter(a=>a.present==1).length;
  const missed=att.filter(a=>a.present==0).length;
  document.getElementById('att-summary').textContent=`✅${came} ❌${missed}`;
  document.getElementById('att-list').innerHTML = att.length
    ? att.map((a,i)=>`<div class="att-item">
        <div style="font-size:13px;font-weight:600;min-width:0;flex:1">
          <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${a.student_name}</div>
          <div style="font-size:11px;color:var(--text2)">${a.group_name||'—'}</div>
        </div>
        <div class="att-btns">
          <button class="btn-sm green ${a.present==1?'':'opacity'}" onclick="markAtt(${a.student_id},'${a.student_name}',true)" style="${a.present==1?'opacity:1':'opacity:0.5'}">✅</button>
          <button class="btn-sm red" onclick="markAtt(${a.student_id},'${a.student_name}',false)" style="${a.present==0?'opacity:1':'opacity:0.5'}">❌</button>
        </div>
      </div>`).join('')
    : '<div class="empty"><div class="empty-icon">✅</div><div class="empty-text">O\'quvchi yo\'q</div></div>';
}
async function markAtt(id,name,present){
  await api('POST','/api/attendance',{student_id:id,student_name:name,present});
  toast(present?'✅ Keldi belgilandi':'❌ Kelmadi belgilandi');
  loadAttendance();
}

// ── REPORTS ──────────────────────────────────────────
async function loadReports(){
  const [stats,teachers,groups,payments]=await Promise.all([
    api('GET','/api/stats'),api('GET','/api/teachers'),
    api('GET','/api/groups'),api('GET','/api/payments')
  ]);
  const paid=payments.filter(p=>p.status==='paid').reduce((a,b)=>a+(b.amount||0),0);
  const total=payments.reduce((a,b)=>a+(b.amount||0),0);
  const pct=total?Math.round(paid/total*100):0;
  document.getElementById('rep-content').innerHTML = `
    <div class="stats-row">
      <div class="stat"><div class="stat-label">O'quvchilar</div><div class="stat-val blue">${stats.students}</div></div>
      <div class="stat"><div class="stat-label">Guruhlar</div><div class="stat-val purple">${stats.groups}</div></div>
      <div class="stat"><div class="stat-label">Daromad</div><div class="stat-val green" style="font-size:18px">${fmt(stats.income)}</div></div>
      <div class="stat"><div class="stat-label">Qarzdorlar</div><div class="stat-val orange">${stats.debts}</div></div>
    </div>
    <div class="card">
      <div class="card-header"><div class="card-title">📈 To'lov bajarilishi</div></div>
      <div style="padding:16px">
        <div style="text-align:center;font-size:36px;font-weight:800;color:var(--green);margin-bottom:8px">${pct}%</div>
        <div class="progress" style="height:12px"><div class="progress-bar" style="width:${pct}%"></div></div>
        <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text2);margin-top:8px">
          <span>To'langan: ${fmt(paid)} so'm</span><span>Jami: ${fmt(total)} so'm</span>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-header"><div class="card-title">👨‍🏫 O'qituvchilar faoliyati</div></div>
      <div style="padding:12px 16px">
        ${teachers.map(t=>{
          const cnt=groups.filter(g=>g.teacher_id==t.id).length;
          return `<div style="margin-bottom:12px">
            <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px">
              <span>${t.name}</span><span style="color:var(--accent)">${cnt} guruh</span>
            </div>
            <div class="progress"><div class="progress-bar" style="width:${groups.length?Math.max(cnt/groups.length*100,5):5}%"></div></div>
          </div>`;
        }).join('')||'<div class="empty-text" style="color:var(--text3)">O\'qituvchi yo\'q</div>'}
      </div>
    </div>`;
}

// ── MODALS ───────────────────────────────────────────
function openSheet(id){document.getElementById(id).classList.add('open')}
function closeSheet(id){document.getElementById(id).classList.remove('open')}

async function openAdd(){
  if(currentPage==='teachers'){openSheet('sheet-teacher');return}
  if(currentPage==='groups'){
    const teachers=await api('GET','/api/teachers');
    const sel=document.getElementById('g-teacher');
    sel.innerHTML='<option value="">-- Tanlang --</option>'+teachers.map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
    openSheet('sheet-group');return;
  }
  // default: student
  const groups=await api('GET','/api/groups');
  const sel=document.getElementById('s-group');
  sel.innerHTML='<option value="">-- Tanlang --</option>'+groups.map(g=>`<option value="${g.id}" data-name="${g.name}">${g.name}</option>`).join('');
  openSheet('sheet-student');
}

async function submitStudent(){
  const name=document.getElementById('s-name').value.trim();
  const sur=document.getElementById('s-surname').value.trim();
  if(!name){toast('❌ Ism kiriting!','red');return}
  const sel=document.getElementById('s-group');
  const gname=sel.options[sel.selectedIndex]?.dataset?.name||'';
  await api('POST','/api/students',{
    name:name+' '+sur,phone:document.getElementById('s-phone').value,
    group_id:sel.value||null,group_name:gname,
    pay_status:document.getElementById('s-status').value,
    amount:parseInt(document.getElementById('s-amount').value)||0
  });
  closeSheet('sheet-student');
  ['s-name','s-surname','s-phone','s-amount'].forEach(id=>document.getElementById(id).value='');
  toast(`✅ ${name} ${sur} qo'shildi!`);
  loadPage(currentPage);
}

async function submitTeacher(){
  const name=document.getElementById('t-name').value.trim();
  if(!name){toast('❌ Ism kiriting!','red');return}
  await api('POST','/api/teachers',{
    name,subject:document.getElementById('t-subject').value,
    phone:document.getElementById('t-phone').value,
    salary:parseInt(document.getElementById('t-salary').value)||0
  });
  closeSheet('sheet-teacher');
  ['t-name','t-subject','t-phone','t-salary'].forEach(id=>document.getElementById(id).value='');
  toast(`✅ ${name} qo'shildi!`);
  loadPage(currentPage);
}

async function submitGroup(){
  const name=document.getElementById('g-name').value.trim();
  if(!name){toast('❌ Nom kiriting!','red');return}
  const tSel=document.getElementById('g-teacher');
  await api('POST','/api/groups',{
    name,subject:document.getElementById('g-subject').value,
    teacher_id:tSel.value||null,
    teacher_name:tSel.options[tSel.selectedIndex]?.text||'',
    days:document.getElementById('g-days').value,
    start_time:document.getElementById('g-start').value,
    end_time:document.getElementById('g-end').value
  });
  closeSheet('sheet-group');
  ['g-name','g-subject'].forEach(id=>document.getElementById(id).value='');
  toast(`✅ "${name}" guruhi qo'shildi!`);
  loadPage(currentPage);
}

async function delItem(res,id){
  if(!confirm('O\'chirishni tasdiqlaysizmi?'))return;
  await api('DELETE',`/api/${res}/${id}`);
  toast('🗑 O\'chirildi');
  loadPage(currentPage);
}

// ── HELPERS ──────────────────────────────────────────
function fmt(n){return Number(n||0).toLocaleString('uz-UZ')}
function payLbl(s){return s==='paid'?'✅ To\'langan':s==='debt'?'❌ Qarz':'⏳ Kutilmoqda'}

function toast(msg,type='green'){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.style.borderColor=type==='red'?'var(--red)':'var(--green)';
  t.classList.add('show');
  clearTimeout(t._timer);
  t._timer=setTimeout(()=>t.classList.remove('show'),2500);
}

function filterList(listId,val){
  document.querySelectorAll(`#${listId} .list-item`).forEach(el=>{
    const name=el.dataset.name||el.textContent.toLowerCase();
    el.style.display=name.includes(val.toLowerCase())?'':'none';
  });
}

// Close sheets on overlay click
document.querySelectorAll('.sheet-overlay').forEach(o=>{
  o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('open')});
});

// Server status
async function checkServer(){
  try{
    await fetch('/api/stats',{signal:AbortSignal.timeout(3000)});
    document.getElementById('srv-dot').classList.remove('offline');
  }catch{
    document.getElementById('srv-dot').classList.add('offline');
  }
}

// ── INIT ─────────────────────────────────────────────
checkServer();
loadDashboard();
setInterval(checkServer,15000);
</script>
</body>
</html>
